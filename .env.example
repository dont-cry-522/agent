# 语雀 API 配置
# 从语雀后台获取: https://www.yuque.com/settings/tokens
YUQUE_TOKEN=your_yuque_token_here
# 语雀个人/团队命名空间，例如: your_name 或 team_name
YUQUE_NAMESPACE=your_namespace_here

# DeepSeek API 配置
# 从 https://platform.deepseek.com/api_keys 获取
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Embedding 模型配置
# 本地 sentence-transformers 模型名称
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5

# Reranker 模型配置
# Cross-encoder 精排模型，下载后缓存到本地（~2.2 GB）
# 不需要可注释或删除，程序会跳过 Rerank
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3

# 向量库配置
FAISS_INDEX_PATH=data/faiss

# 文档存储配置
MARKDOWN_STORE_PATH=data/markdown

# 服务配置
HOST=0.0.0.0
PORT=8000
